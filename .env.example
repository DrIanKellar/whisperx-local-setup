# Copy this file to `.env` and fill in your token.
# `.env` is gitignored / never share it.
#
# Get a token at: https://huggingface.co/settings/tokens  (Read scope is enough)
# Accept the model licences (one-time, free) on these pages while logged in:
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_replace_me

# Optional: where transcripts go by default. If unset, they land in
# <project>/transcripts/. Override per-run with --out-dir.
# TRANSCRIPTS_DIR=C:\Users\Ian Kellar\OneDrive\Documents\Transcripts
